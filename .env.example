# Read-only GitHub API token. Optional for public repositories, but increases rate limits.
GITHUB_TOKEN=

# DeepSeek refinement. Leave empty to use deterministic heuristics.
DEEPSEEK_API_KEY=
LLM_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Real GitHub writes are deliberately disabled by default.
ENABLE_GITHUB_WRITE=false
GITHUB_WRITE_TOKEN=
